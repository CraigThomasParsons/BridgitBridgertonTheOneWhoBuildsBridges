{
    "manifest_version": 3,
    "name": "ChatProjects Token Refresher",
    "version": "1.0",
    "description": "Automatically refreshes ChatGPT session token for ChatProjects bridge.",
    "permissions": [
        "cookies",
        "alarms",
        "storage"
    ],
    "host_permissions": [
        "https://chatgpt.com/*",
        "https://*.chatgpt.com/*",
        "https://*.openai.com/*",
        "http://localhost/*"
    ],
    "background": {
        "service_worker": "background.js"
    }
}
